---
import BaseLayout from './BaseLayout.astro';
import TagPill from '../components/TagPill.astro';
import TOC from '../components/TOC.astro';
import SeriesBox from '../components/SeriesBox.astro';
import { getReadingTime } from '../lib/reading-time';
import { getCollection } from 'astro:content';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  series?: string;
  seriesOrder?: number;
  updated?: Date;
  headings: MarkdownHeading[];
  rawContent: string;
}

const {
  title,
  date,
  description,
  tags,
  series,
  seriesOrder,
  updated,
  headings,
  rawContent,
} = Astro.props;

const readingTime = getReadingTime(rawContent);

const formatDate = (d: Date) =>
  d.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

// Get series posts if this is part of a series
let seriesPosts: Array<{
  id: string;
  title: string;
  seriesOrder: number;
}> = [];

if (series) {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  seriesPosts = allPosts
    .filter((p) => p.data.series === series)
    .map((p) => ({
      id: p.id,
      title: p.data.title,
      seriesOrder: p.data.seriesOrder ?? 0,
    }))
    .sort((a, b) => a.seriesOrder - b.seriesOrder);
}

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} ogType="article">
  <article class="prose">
    <!-- Post header -->
    <header class="mb-8">
      <h1 class="!mt-0 !mb-3 text-3xl sm:text-4xl">{title}</h1>
      <div
        class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-(--color-text-secondary)"
      >
        <time datetime={date.toISOString()}>
          {formatDate(date)}
        </time>
        {
          updated && (
            <span>
              (updated{' '}
              <time datetime={updated.toISOString()}>
                {formatDate(updated)}
              </time>
              )
            </span>
          )
        }
        <span aria-hidden="true">&middot;</span>
        <span>{readingTime}</span>
      </div>
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => <TagPill tag={tag} />)}
      </div>
    </header>

    <!-- TOC -->
    {headings.length > 0 && <TOC headings={headings} />}

    <!-- Series box -->
    {
      series && seriesPosts.length > 1 && (
        <SeriesBox
          series={series}
          posts={seriesPosts}
          currentId={Astro.params.slug ?? ''}
          base={base}
        />
      )
    }

    <!-- Content -->
    <div class="mt-8">
      <slot />
    </div>

    <!-- Series box (bottom) -->
    {
      series && seriesPosts.length > 1 && (
        <div class="mt-12">
          <SeriesBox
            series={series}
            posts={seriesPosts}
            currentId={Astro.params.slug ?? ''}
            base={base}
          />
        </div>
      )
    }
  </article>
</BaseLayout>
