---
import '../styles/global.css';
import DarkModeToggle from '../components/DarkModeToggle.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description = 'A personal blog about programming and technology',
  ogImage,
  ogType = 'website',
} = Astro.props;

const siteTitle = 'leeyc blog';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="ko" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle}
      href={`${base}rss.xml`}
    />

    <!-- Dark mode: prevent FOUC -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia(
          '(prefers-color-scheme: dark)'
        ).matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body
    class="min-h-screen flex flex-col bg-(--color-bg) text-(--color-text) motion-safe:transition-colors motion-safe:duration-200"
  >
    <a
      href="#main-content"
      class="skip-link"
    >
      Skip to content
    </a>

    <!-- Header -->
    <header
      class="sticky top-0 z-40 border-b border-(--color-border) bg-(--color-bg)/95 backdrop-blur-sm"
    >
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <nav
          class="flex items-center justify-between h-14"
          aria-label="Main navigation"
        >
          <a
            href={base}
            class="text-lg font-bold tracking-tight hover:text-(--color-accent) motion-safe:transition-colors motion-safe:duration-200 cursor-pointer"
          >
            {siteTitle}
          </a>

          <div class="flex items-center gap-1">
            <a
              href={`${base}tags/`}
              class="inline-flex items-center justify-center min-h-11 min-w-11 p-2 rounded-lg hover:bg-(--color-bg-secondary) motion-safe:transition-colors motion-safe:duration-200 cursor-pointer text-sm font-medium"
              aria-label="Tags"
            >
              Tags
            </a>
            <a
              href={`${base}rss.xml`}
              class="inline-flex items-center justify-center min-h-11 min-w-11 p-2 rounded-lg hover:bg-(--color-bg-secondary) motion-safe:transition-colors motion-safe:duration-200 cursor-pointer"
              aria-label="RSS Feed"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 11a9 9 0 0 1 9 9"></path>
                <path d="M4 4a16 16 0 0 1 16 16"></path>
                <circle cx="5" cy="19" r="1"></circle>
              </svg>
            </a>
            <DarkModeToggle />
          </div>
        </nav>
      </div>
    </header>

    <!-- Main -->
    <main id="main-content" class="flex-1">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 py-8 sm:py-12">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer
      class="border-t border-(--color-border) py-6 text-center text-sm text-(--color-text-secondary)"
    >
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <p>&copy; {new Date().getFullYear()} leeyc. Built with Astro.</p>
      </div>
    </footer>
  </body>
</html>
