---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import TagPill from '../components/TagPill.astro';
import SearchBox from '../components/SearchBox.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Collect all tags with counts
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="leeyc blog">
  <section class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">
      Posts
    </h1>
    <p class="text-(--color-text-secondary) mb-6">
      Programming notes and learnings.
    </p>

    <!-- Search -->
    <div class="mb-6">
      <SearchBox />
    </div>

    <!-- Tag filters -->
    {
      sortedTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {sortedTags.map(([tag, count]) => (
            <TagPill tag={tag} count={count} />
          ))}
        </div>
      )
    }
  </section>

  <!-- Post list -->
  <section class="space-y-4" aria-label="Blog posts">
    {
      posts.length === 0 ? (
        <p class="text-(--color-text-secondary) text-center py-12">
          No posts yet.
        </p>
      ) : (
        posts.map((post) => (
          <div
            data-post-card
            data-title={post.data.title}
            data-description={post.data.description}
            data-tags={post.data.tags.join(',')}
          >
            <PostCard
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
              tags={post.data.tags}
              slug={post.id}
            />
          </div>
        ))
      )
    }
  </section>
</BaseLayout>
