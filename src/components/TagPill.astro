---
interface Props {
  tag: string;
  count?: number;
  active?: boolean;
}

const { tag, count, active = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const TAG_COLORS: Record<string, string> = {
  rust: 'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300',
  react:
    'bg-cyan-100 text-cyan-800 dark:bg-cyan-900/40 dark:text-cyan-300',
  typescript:
    'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
  study:
    'bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300',
};

const defaultColor =
  'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300';
const colorClass = TAG_COLORS[tag.toLowerCase()] ?? defaultColor;
const activeClass = active
  ? 'ring-2 ring-(--color-accent) ring-offset-1'
  : '';
---

<a
  href={`${base}tags/${encodeURIComponent(tag)}/`}
  class:list={[
    'inline-flex items-center gap-1 rounded-md px-2.5 py-1 text-xs font-medium',
    'motion-safe:transition-all motion-safe:duration-200',
    'hover:opacity-80 cursor-pointer',
    'min-h-7',
    colorClass,
    activeClass,
  ]}
>
  {tag}
  {count !== undefined && <span class="opacity-70">({count})</span>}
</a>
