---
import TagPill from './TagPill.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
  slug: string;
}

const { title, date, description, tags, slug } = Astro.props;
const base = import.meta.env.BASE_URL;

const formatDate = (d: Date) =>
  d.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<article
  class="group rounded-lg border border-(--color-border) p-5 motion-safe:transition-all motion-safe:duration-200 hover:border-(--color-accent)/50 hover:shadow-sm"
>
  <a href={`${base}${slug}/`} class="block cursor-pointer">
    <h2
      class="text-lg font-semibold group-hover:text-(--color-accent) motion-safe:transition-colors motion-safe:duration-200"
    >
      {title}
    </h2>
    <time
      class="mt-1 block text-sm text-(--color-text-secondary)"
      datetime={date.toISOString()}
    >
      {formatDate(date)}
    </time>
    <p class="mt-2 text-sm text-(--color-text-secondary) line-clamp-2">
      {description}
    </p>
  </a>
  <div class="mt-3 flex flex-wrap gap-1.5">
    {tags.map((tag) => <TagPill tag={tag} />)}
  </div>
</article>
