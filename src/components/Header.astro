---
import IconSearch from "@/assets/icons/IconSearch.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { withBase } from "@/utils/getBase";
import { CATEGORY_MAP, type CategorySlug } from "@/utils/categoryConfig";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const segments = currentPath.split("/").filter(Boolean);
  const targetSegments = path.split("/").filter(Boolean);
  return segments.length >= targetSegments.length &&
    targetSegments.every((seg, i) => segments[i] === seg);
};

const categories = Object.entries(CATEGORY_MAP) as [CategorySlug, string][];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="app-layout">
  <div class="flex items-center justify-between border-b border-border-strong py-4 sm:py-6">
    <a
      href={withBase("/")}
      class="text-xl font-semibold whitespace-nowrap text-foreground sm:text-2xl"
    >
      {SITE.title}
    </a>
    <LinkButton
      href={withBase("/search")}
      class:list={[
        "focus-outline flex p-1",
        { "[&>svg]:stroke-accent": isActive("/search") },
      ]}
      title="Search"
      aria-label="search"
    >
      <IconSearch />
      <span class="sr-only">Search</span>
    </LinkButton>
  </div>
  <nav class="flex items-center gap-2 py-3 sm:gap-3">
    {categories.map(([slug, name]) => (
      <a
        href={withBase(`/categories/${slug}/`)}
        class:list={[
          "rounded-full px-3 py-1 text-sm font-medium transition-colors",
          isActive(`/categories/${slug}`)
            ? "bg-accent text-white"
            : "bg-accent-bg text-accent hover:bg-accent hover:text-white",
        ]}
      >
        {name}
      </a>
    ))}
  </nav>
</header>
