---
interface Props {
  type?: 'info' | 'warning' | 'error' | 'success';
}

const { type = 'info' } = Astro.props;

const styles: Record<string, { bg: string; border: string; icon: string }> = {
  info: {
    bg: 'bg-(--color-callout-info)',
    border: 'border-blue-400 dark:border-blue-600',
    icon: `<circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path>`,
  },
  warning: {
    bg: 'bg-(--color-callout-warning)',
    border: 'border-amber-400 dark:border-amber-600',
    icon: `<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path>`,
  },
  error: {
    bg: 'bg-(--color-callout-error)',
    border: 'border-red-400 dark:border-red-600',
    icon: `<circle cx="12" cy="12" r="10"></circle><path d="m15 9-6 6"></path><path d="m9 9 6 6"></path>`,
  },
  success: {
    bg: 'bg-(--color-callout-success)',
    border: 'border-green-400 dark:border-green-600',
    icon: `<circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path>`,
  },
};

const s = styles[type] ?? styles.info;
---

<div
  class:list={[
    'not-prose my-4 flex gap-3 rounded-lg border-l-4 p-4 text-sm',
    s.bg,
    s.border,
  ]}
  role={type === 'error' || type === 'warning' ? 'alert' : 'note'}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="shrink-0 mt-0.5"
    aria-hidden="true"
    set:html={s.icon}
  />
  <div class="flex-1 [&>p]:mb-0">
    <slot />
  </div>
</div>
